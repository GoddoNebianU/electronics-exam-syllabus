        "text": "磁通连续积分形式",
        "latex": "\\oint_{S}\\mathbf{B}\\cdot d\\mathbf{S}=0"
      },
      {
        "text": "用散度定理",
        "latex": "\\int_{V}(\\nabla\\cdot\\mathbf{B})\\,dV=0"
      },
      {
        "text": "对任意体积成立",
        "latex": "\\nabla\\cdot\\mathbf{B}=0"
      }
    ]
  },
