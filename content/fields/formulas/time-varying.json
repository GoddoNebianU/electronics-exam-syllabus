    "cat": "time-varying",
    "title": "本构关系（介质特性）",
    "latex": "\\mathbf{D}=\\varepsilon\\mathbf{E},\\quad\\mathbf{B}=\\mu\\mathbf{H},\\quad\\mathbf{J}=\\sigma\\mathbf{E}",
    "symbols": [
      "D",
